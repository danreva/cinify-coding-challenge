# Normalize line endings: LF in the repo, OS-native on checkout
* text=auto eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binaries — no line-ending conversion
*.png binary
*.ico binary
*.jpg binary
*.woff2 binary
